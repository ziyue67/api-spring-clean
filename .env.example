# Server
PORT=3000

# Database
DATABASE_URL=jdbc:postgresql://localhost:55432/youth_night_school

# Redis
REDIS_URL=redis://localhost:56379
REDIS_TLS=false
REDIS_TLS_REJECT_UNAUTHORIZED=true

# JWT (min 256 bits / 32 bytes, e.g. 64 hex chars)
JWT_SECRET=your-jwt-secret-change-in-production-32b

# WeChat Mini Program
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret

# Session key encryption (32+ chars)
SESSION_KEY_ENCRYPTION_KEY=your-session-key-encryption-key-32bytes

# Admin openids (comma-separated)
ADMIN_OPENIDS=test_admin_openid

# CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:10086

# Optional
ENABLE_PHONE_LOOKUP=false
PERF_SLOW_REQUEST_MS=3000
PERF_VERY_SLOW_REQUEST_MS=10000
ENABLE_PERF_HEADERS=true
ENABLE_PERF_METRICS=true
REQUEST_TIMEOUT_MS=30000
